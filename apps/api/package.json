{
  "name": "@recall/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "MODE=worker tsx watch src/worker.ts",
    "start": "tsx src/index.ts",
    "start:worker": "MODE=worker tsx src/worker.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "build": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@clerk/backend": "1.21.6",
    "@recall/shared": "workspace:*",
    "drizzle-orm": "0.36.4",
    "fastify": "5.1.0",
    "ioredis": "5.4.2",
    "postgres": "3.4.5",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "@vitest/coverage-v8": "2.1.8",
    "drizzle-kit": "0.28.1",
    "testcontainers": "10.16.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
