{
  "$schema": "https://railway.com/railway.schema.json",
  "_note": "Reference descriptor for the three Railway services deployed from this monorepo (docs/01 §1). 'api' and 'worker' share Dockerfile.api — the worker is the same image booted with MODE=worker. Provision Postgres (pgvector) + Redis as Railway add-ons. apps/web deploys as the third service (or Vercel).",
  "services": {
    "api": {
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "infra/Dockerfile.api" },
      "deploy": {
        "startCommand": "pnpm --filter @recall/api start",
        "healthcheckPath": "/internal/health",
        "restartPolicyType": "ON_FAILURE",
        "numReplicas": 1
      },
      "env": { "MODE": "http" }
    },
    "worker": {
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "infra/Dockerfile.api" },
      "deploy": {
        "startCommand": "pnpm --filter @recall/api start:worker",
        "restartPolicyType": "ON_FAILURE",
        "numReplicas": 1
      },
      "env": { "MODE": "worker" }
    },
    "web": {
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "infra/Dockerfile.web" },
      "deploy": {
        "startCommand": "pnpm --filter @recall/web start",
        "restartPolicyType": "ON_FAILURE",
        "numReplicas": 1
      }
    }
  }
}
