# ─────────────────────────────────────────────────────────────────────────────
# Recall environment registry (authoritative: docs/01-ARCHITECTURE.md §8)
# Copy to .env and fill in. config.ts (apps/api) parses + fail-fast validates this.
# Keys are promoted from optional → required in the phase that first uses them.
# ─────────────────────────────────────────────────────────────────────────────

# --- Runtime (Phase 0) ---
NODE_ENV=development
MODE=http                       # http | worker  (worker = same image, MODE=worker)
PORT=3001
APP_URL=http://localhost:3000
INTERNAL_API_KEY=change-me-min-16-chars
TZ_DISPLAY=Asia/Jakarta

# --- Datastores (Phase 1) ---
DATABASE_URL=postgres://user:pass@localhost:5432/recall
REDIS_URL=redis://localhost:6379

# --- Auth: Clerk (Phase 1 API / Phase 4 web). Google OAuth+calendar scopes in Clerk dashboard ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- Object storage: Cloudflare R2 (Phase 2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- Model providers (Phase 3 / 6) ---
GROQ_API_KEY=
# STT quality levers (both optional, both significant):
# ISO-639-1 hint. Unset = Whisper re-detects every 30s and drifts on ID/EN code-switching.
STT_LANGUAGE=
# Initial prompt — seed people/company/product names so they stop being spelled phonetically.
# Only the last ~224 tokens are used, so put the highest-value terms last.
STT_PROMPT=
DEEPSEEK_API_KEY=
# Embeddings: Cloudflare Workers AI @cf/baai/bge-m3 (1024-dim, matches memories.embedding).
# Key = a Cloudflare API token with the "Workers AI: Read" permission.
EMBEDDINGS_API_KEY=
EMBEDDINGS_URL=https://api.cloudflare.com/client/v4/accounts/<account id>/ai/run/@cf/baai/bge-m3

# --- WhatsApp Cloud API (Recall owns the WABA connection directly) ---
# Meta App Secret — verifies X-Hub-Signature-256 on inbound webhooks.
META_APP_SECRET=
# Any string you choose; enter the same value in Meta's webhook config.
META_WEBHOOK_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
